@page "/person/list"
@using Microsoft.EntityFrameworkCore
@inject InsCorpDbContext db
@inject NavigationManager nav

<style type="text/css">

</style>

<h3 style="color:aqua">Seznam osob:</h3>

@if(loading)
{
	<p>načítám..</p>
}
else
{
<table class="table">
	<tr>
		<td>
			Jméno
		</td>
		<td>
			Přijmení
		</td>
		<td>
			Dat.nar.
		</td>
		<td>
			Email
		</td>
		<td>
			akce
		</td>

	</tr>
	@foreach (var person in people)
	{
		<tr>
			<td>
				@person.FirstName
			</td>
			<td>
				@person.LastName
			</td>
			<td>
				@person.DateOfBirth.ToShortDateString()
			</td>
			<td>
				<a href="/person/detail/@person.Id">@person.Email</a>
			</td>
			<td>
				<a class="btn btn-primary btn-sm" style="background:orange" href="/person/edit/@person.Id">edit</a>
			</td>
			<td>
				<button class="btn btn-primary btn-sm" style="background:green" @onclick="() => EditPerson(person.Id)">edit</button>
			</td>
		</tr>
	}
</table>

<div class="row">
	<div class="col-2">
		<button disabled="@prevDisabled" class="btn btn-primary" @onclick="prev">Předchozí</button>
	</div>
	<div class="col-2">
		<button class="btn btn-primary @btnExtraClass" @onclick="next">Další</button>
	</div>
</div>
}

@code {
	bool loading = false;
	List<Person> people = new();
	int currentPage = 0;
	string btnExtraClass = "btn-sm";

	bool prevDisabled
	{
		get
		{
			return currentPage == 0;
		}

	}

	protected async override Task OnInitializedAsync()
	{
		await LoadPeople();
	}

	async Task LoadPeople()
	{
		loading = true;
		StateHasChanged();

		await Task.Delay(2000);
		people = await db.Persons.Skip(currentPage * 20).Take(20).ToListAsync();

		loading = false;
		StateHasChanged();

	}

	void EditPerson(int id)
	{
		nav.NavigateTo($"/person/edit/{id}");
	}

	void prev()
	{
		if (currentPage > 0)
			--currentPage;
		LoadPeople();
	}

	void next()
	{
		++currentPage;
		LoadPeople();
	}
}
