@page "/person/search"

<h3>Hledej osoby podle emailu:</h3>

<EditForm Model="searchterm" OnSubmit="SearchPerson">
	<div class="row">
		<div class="col-auto">
			<label>Email:</label>
		</div>
		<div class="col-auto">
			<InputText @bind-Value="searchterm" class="form-control"/>
		</div>
		<div class="col-auto">
			<button class="btn btn-primary" type="submit">Hledej</button>
		</div>
	</div>
</EditForm>

@code {
	string searchterm = "";

	async Task SearchPerson()
	{
		using HttpClient client = new HttpClient();

		var apiurl = "https://localhost:7033";

		var result = await client.GetFromJsonAsync<List<Person>>($"{apiurl}/api/person/SerchByEmail/{searchterm}");
		
	}
}
